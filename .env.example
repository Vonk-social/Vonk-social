# Vonk Environment Configuration
# Copy to .env and fill in your values

# Domain
PUBLIC_DOMAIN=vonk.social
PUBLIC_URL=https://vonk.social

# Database
DATABASE_URL=postgres://vonk:CHANGE_ME@vonk-db:5432/vonk
DB_PASS=CHANGE_ME

# Redis/Valkey
REDIS_URL=redis://vonk-cache:6379

# Object Storage (MinIO)
S3_ENDPOINT=http://vonk-media:9000
S3_BUCKET=vonk-media
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# Auth - Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth - Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Auth - GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT
JWT_SECRET=CHANGE_ME
JWT_EXPIRY=7d

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@vonk.social

# CDN (optional)
CDN_URL=

# Environment
RUST_LOG=info
ENVIRONMENT=production
