# Vonk Environment Configuration
# Copy to .env and fill in your values.
# For LOCAL DEVELOPMENT (docker-compose.dev.yml), the defaults below work out of the box
# except for the entries marked CHANGE_ME and the Google OAuth credentials.

# ── URLs ─────────────────────────────────────────────────────
# API_URL is where the Rust backend listens (from the browser's perspective).
# WEB_URL is where the SvelteKit frontend lives.
# In production both point to the same origin (nginx routes) e.g.
# https://vonk.openview.be for staging.
API_URL=http://localhost:5173
WEB_URL=http://localhost:5173
# Port the Rust API binds to on the host. Defaults to 8080 locally; staging
# picks a free port (e.g. 3501) to avoid collision with existing services.
API_PORT=8080
PUBLIC_DOMAIN=vonk.social
PUBLIC_URL=https://vonk.social

# ── Database ─────────────────────────────────────────────────
# Dev: localhost:5433 (mapped by docker-compose.dev.yml)
# Prod: internal docker network hostname
DATABASE_URL=postgres://vonk:vonk_dev_password@localhost:5433/vonk
DB_PASS=vonk_dev_password

# ── Cache / Valkey ───────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Object Storage (MinIO, S3-compatible) ────────────────────
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=vonk-media
S3_ACCESS_KEY=vonkdev
S3_SECRET_KEY=vonkdev123
# Force path-style addressing (required by MinIO)
S3_FORCE_PATH_STYLE=true

# ── Auth: Google OAuth ───────────────────────────────────────
# Create credentials in Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs:
#   http://localhost:8080/api/auth/callback/google
#   https://dev.vonk.social/api/auth/callback/google
# See docs/notes/auth.md for the full walkthrough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth: Apple Sign In (Phase 2) ────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ── Auth: GitHub OAuth (Phase 2) ─────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── JWT & sessions ───────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
# Short-lived access token
JWT_ACCESS_TTL_SECS=900           # 15 minutes
# Long-lived refresh token (sessions.expires_at)
REFRESH_TTL_SECS=2592000          # 30 days
# Salt for hashed IP addresses in sessions (rotate periodically in production).
# Generate with: openssl rand -hex 32
IP_HASH_SALT=CHANGE_ME_generate_with_openssl_rand_hex_32
# Cookie domain. Leave empty for localhost; set to .vonk.social in production.
COOKIE_DOMAIN=

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@vonk.social

# ── CDN (optional) ───────────────────────────────────────────
CDN_URL=

# ── Environment ──────────────────────────────────────────────
RUST_LOG=vonk_api=debug,tower_http=info,axum=info
ENVIRONMENT=development            # development | production
